generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  VISITOR
  STUDENT
  TEACHER
  ADMIN
}

enum UserStatus {
  PENDING
  ACTIVE
  INACTIVE
  REJECTED
}

enum EnrollmentStatus {
  PENDING
  APPROVED
  REJECTED
  NEEDS_CONTACT
}

enum GroupStatus {
  ACTIVE
  INACTIVE
}

model User {
  id                           String      @id @default(cuid())
  fullName                     String
  email                        String      @unique
  passwordHash                 String
  whatsapp                     String?
  role                         UserRole
  status                       UserStatus
  groupName                    String?
  groupSlug                    String?
  adminNote                    String      @default("")
  enrollmentId                 String?     @unique
  temporaryPasswordGeneratedAt DateTime?
  mustChangePassword           Boolean     @default(false)
  passwordChangedAt            DateTime?
  createdAt                    DateTime    @default(now())
  updatedAt                    DateTime    @updatedAt
  enrollment                   Enrollment? @relation(fields: [enrollmentId], references: [id], onDelete: SetNull)
  authSessions                 AuthSession[]
  passwordResetTokens          PasswordResetToken[]
}

model AuthSession {
  id               String   @id
  userId           String
  createdAt        DateTime @default(now())
  expiresAt        DateTime
  revokedAt        DateTime?
  lastSeenAt       DateTime?
  userAgentSummary String?
  ipHash           String?
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@index([revokedAt])
  @@index([userId, revokedAt])
}

model PasswordResetToken {
  id              String   @id @default(cuid())
  userId          String
  tokenHash       String   @unique
  createdAt       DateTime @default(now())
  expiresAt       DateTime
  usedAt          DateTime?
  invalidatedAt   DateTime?
  requestedIpHash String?
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@index([usedAt])
  @@index([invalidatedAt])
  @@index([userId, usedAt, invalidatedAt])
}

model Enrollment {
  id                  String           @id @default(cuid())
  fullName            String
  email               String
  whatsapp            String
  groupInterest       String
  alreadyParticipates String
  message             String           @default("")
  status              EnrollmentStatus @default(PENDING)
  createdAt           DateTime         @default(now())
  reviewedAt          DateTime?
  reviewedBy          String?
  teacherNote         String           @default("")
  user                User?

  @@index([status])
  @@index([groupInterest])
}

model StudyGroup {
  id               String      @id
  name             String
  meetingDay       String
  meetingTime      String
  participantCount Int
  bookTitle        String
  meetUrl          String
  description      String
  status           GroupStatus @default(ACTIVE)
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt
}

model AuditLog {
  id         String   @id @default(cuid())
  occurredAt DateTime @default(now())
  actorName  String
  actorRole  UserRole
  action     String
  entity     String
  note       String
}
