generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  VISITOR
  STUDENT
  TEACHER
  ADMIN
}

enum UserStatus {
  PENDING
  ACTIVE
  INACTIVE
  REJECTED
}

enum EnrollmentStatus {
  PENDING
  APPROVED
  REJECTED
  NEEDS_CONTACT
}

enum GroupStatus {
  ACTIVE
  INACTIVE
}

enum InvitationType {
  ENROLLMENT_APPROVAL
  ADMIN_REINVITE
}

enum DeliveryStatus {
  PENDING
  SENT
  FAILED
  NOT_CONFIGURED
}

enum KnowledgeBookStatus {
  ACTIVE
  ARCHIVED
}

enum KnowledgeDocumentType {
  README
  ORIENTACOES
  DEMO
  VISAO_GERAL
  TEMA
  CAPITULO
  FAQ
  PALAVRAS_CHAVE
  OTHER
}

enum KnowledgeEditorialStatus {
  DRAFT
  NEEDS_REVIEW
  REVIEWED
  APPROVED
  ARCHIVED
}

model User {
  id                           String      @id @default(cuid())
  fullName                     String
  email                        String      @unique
  passwordHash                 String
  whatsapp                     String?
  role                         UserRole
  status                       UserStatus
  groupName                    String?
  groupSlug                    String?
  adminNote                    String      @default("")
  enrollmentId                 String?     @unique
  accountActivatedAt           DateTime?
  temporaryPasswordGeneratedAt DateTime?
  mustChangePassword           Boolean     @default(false)
  passwordChangedAt            DateTime?
  createdAt                    DateTime    @default(now())
  updatedAt                    DateTime    @updatedAt
  enrollment                   Enrollment? @relation(fields: [enrollmentId], references: [id], onDelete: SetNull)
  authSessions                 AuthSession[]
  passwordResetTokens          PasswordResetToken[]
  accountInvitations           AccountInvitation[] @relation("AccountInvitationRecipient")
  sentAccountInvitations       AccountInvitation[] @relation("AccountInvitationInviter")
  reviewedKnowledgeDocuments   KnowledgeDocument[] @relation("KnowledgeDocumentReviewer")
  approvedKnowledgeDocuments   KnowledgeDocument[] @relation("KnowledgeDocumentApprover")
}

model AuthSession {
  id               String   @id
  userId           String
  createdAt        DateTime @default(now())
  expiresAt        DateTime
  revokedAt        DateTime?
  lastSeenAt       DateTime?
  userAgentSummary String?
  ipHash           String?
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@index([revokedAt])
  @@index([userId, revokedAt])
}

model PasswordResetToken {
  id              String   @id @default(cuid())
  userId          String
  tokenHash       String   @unique
  createdAt       DateTime @default(now())
  expiresAt       DateTime
  usedAt          DateTime?
  invalidatedAt   DateTime?
  requestedIpHash String?
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@index([usedAt])
  @@index([invalidatedAt])
  @@index([userId, usedAt, invalidatedAt])
}

model AccountInvitation {
  id                     String         @id @default(cuid())
  userId                 String
  tokenHash              String         @unique
  createdAt              DateTime       @default(now())
  expiresAt              DateTime
  acceptedAt             DateTime?
  invalidatedAt          DateTime?
  invitedByUserId        String?
  invitationType         InvitationType
  recipientEmailSnapshot String
  deliveryStatus         DeliveryStatus @default(PENDING)
  deliveredAt            DateTime?
  deliveryFailedAt       DateTime?
  user                   User           @relation("AccountInvitationRecipient", fields: [userId], references: [id], onDelete: Cascade)
  invitedByUser          User?          @relation("AccountInvitationInviter", fields: [invitedByUserId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([expiresAt])
  @@index([acceptedAt])
  @@index([invalidatedAt])
  @@index([deliveryStatus])
  @@index([invitedByUserId])
  @@index([userId, invitationType, acceptedAt, invalidatedAt], map: "AccountInvitation_userId_invitationType_acceptedAt_invalidatedA")
}

model Enrollment {
  id                  String           @id @default(cuid())
  fullName            String
  email               String
  whatsapp            String
  groupInterest       String
  alreadyParticipates String
  message             String           @default("")
  status              EnrollmentStatus @default(PENDING)
  createdAt           DateTime         @default(now())
  reviewedAt          DateTime?
  reviewedBy          String?
  teacherNote         String           @default("")
  user                User?

  @@index([status])
  @@index([groupInterest])
}

model StudyGroup {
  id               String      @id
  name             String
  meetingDay       String
  meetingTime      String
  participantCount Int
  bookTitle        String
  meetUrl          String
  description      String
  status           GroupStatus @default(ACTIVE)
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt
  meetings         StudyMeeting[]
}

model StudyMeeting {
  id                 String     @id @default(cuid())
  groupId            String
  title              String
  description        String?
  startsAt           DateTime
  endsAt             DateTime
  canceledAt         DateTime?
  cancellationReason String?
  createdAt          DateTime   @default(now())
  updatedAt          DateTime   @updatedAt
  group              StudyGroup @relation(fields: [groupId], references: [id], onDelete: Restrict)

  @@index([groupId, startsAt])
}

model AuditLog {
  id         String   @id @default(cuid())
  occurredAt DateTime @default(now())
  actorName  String
  actorRole  UserRole
  action     String
  entity     String
  note       String
}

model KnowledgeBook {
  id          String              @id @default(cuid())
  slug        String              @unique
  title       String
  description String              @default("")
  status      KnowledgeBookStatus @default(ACTIVE)
  sortOrder   Int                 @default(0)
  version     Int                 @default(1)
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
  documents   KnowledgeDocument[]

  @@index([status])
  @@index([sortOrder, title])
}

model KnowledgeDocument {
  id                       String                   @id @default(cuid())
  bookId                   String
  catalogKey               String?                  @unique
  filePath                 String                   @unique
  title                    String
  description              String                   @default("")
  summary                  String                   @default("")
  type                     KnowledgeDocumentType
  tags                     String[]
  sensitiveTopics          String[]
  teacherReviewRecommended Boolean                  @default(false)
  editorialStatus          KnowledgeEditorialStatus @default(DRAFT)
  editorialNotes           String                   @default("")
  sortOrder                Int                      @default(0)
  reviewedAt               DateTime?
  reviewedByUserId         String?
  approvedAt               DateTime?
  approvedByUserId         String?
  version                  Int                      @default(1)
  createdAt                DateTime                 @default(now())
  updatedAt                DateTime                 @updatedAt
  book                     KnowledgeBook            @relation(fields: [bookId], references: [id], onDelete: Restrict)
  reviewedByUser           User?                    @relation("KnowledgeDocumentReviewer", fields: [reviewedByUserId], references: [id], onDelete: SetNull)
  approvedByUser           User?                    @relation("KnowledgeDocumentApprover", fields: [approvedByUserId], references: [id], onDelete: SetNull)

  @@index([bookId])
  @@index([type])
  @@index([editorialStatus])
  @@index([teacherReviewRecommended])
  @@index([bookId, editorialStatus])
  @@index([sortOrder, title])
  @@index([reviewedByUserId])
  @@index([approvedByUserId])
}
