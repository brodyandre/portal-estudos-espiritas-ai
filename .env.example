NODE_ENV=development
PORT=3333
DATABASE_URL=postgresql://postgres:postgres@localhost:5435/portal_estudos_espiritas_ai?schema=public
JWT_SECRET=jwt-secret-demo-local-only
PASSWORD_RECOVERY_PREVIEW_ENABLED=false
PASSWORD_RECOVERY_TTL_MINUTES=30
APP_PUBLIC_URL=http://localhost:5173
# Ative SMTP apenas no ambiente local ou privado onde houver provedor configurado.
SMTP_ENABLED=false
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_SECURE=false
# No Mailpit local, usuario e senha podem ficar vazios.
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_NAME=Portal de Estudos Espiritas
SMTP_FROM_EMAIL=no-reply@example.local
# API local usada pelo fluxo via npm
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:3000,http://127.0.0.1:3000

# URL opcional para o frontend quando voce quiser sobrescrever o padrao.
# No docker-compose, o build da web usa http://localhost:4000.
VITE_API_URL=http://localhost:3333
VITE_APP_MODE=local
VITE_SHOW_REAL_MEET_LINK=true
VITE_ENABLE_ADMIN_FEATURES=true
VITE_ENABLE_TEACHER_FEATURES=true

# Ollama fica fora do docker-compose e pode rodar separado na maquina host.
OLLAMA_MODEL=llama3.1:8b
OLLAMA_BASE_URL=http://127.0.0.1:11434
